<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>ETL Test Report - {{ suite.started_at }}</title>
  <style>
    :root {
      --bg: #050505;
      --panel: #0d0f12;
      --panel-2: #141922;
      --line: rgba(255,255,255,0.12);
      --text: #f4f7fb;
      --soft: #c7d0dc;
      --muted: #8491a3;
      --cyan: #22d3ee;
      --blue: #3b82f6;
      --violet: #8b5cf6;
      --emerald: #34d399;
      --amber: #fbbf24;
      --rose: #fb7185;
    }
    * { box-sizing: border-box; }
    body {
      font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 18% 0%, rgba(34,211,238,0.12), transparent 28rem),
        radial-gradient(circle at 82% 4%, rgba(232,121,249,0.11), transparent 26rem),
        linear-gradient(180deg, #050505, #080a0d 48%, #050505);
      margin: 0;
      padding: 28px;
    }
    .container {
      max-width: 1200px;
      margin: 0 auto;
      background: linear-gradient(180deg, rgba(18,22,27,0.98), rgba(10,12,15,0.98));
      padding: 28px;
      border-radius: 8px;
      border: 1px solid var(--line);
      box-shadow: 0 18px 60px rgba(0,0,0,0.42);
    }
    h1, h2, h3 { color: var(--text); letter-spacing: 0; }
    h1 {
      margin-top: 0;
      background: linear-gradient(90deg, var(--cyan), var(--violet), var(--rose));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    p { color: var(--soft); }
    hr { border: none; height: 1px; background: var(--line); margin: 18px 0; }
    .badge { 
      display: inline-flex;
      align-items: center;
      padding: 0.35em 0.65em; 
      font-size: 75%; 
      font-weight: 700; 
      border-radius: 999px;
      border: 1px solid currentColor;
    }
    .badge-pass  { background: rgba(52,211,153,0.16); color: #86efac; }
    .badge-fail  { background: rgba(251,113,133,0.16); color: #fda4af; }
    .badge-amber { background: rgba(251,191,36,0.16); color: #fcd34d; }
    .badge-gray  { background: rgba(148,163,184,0.14); color: #cbd5e1; }
    
    .warning-banner { 
      background: rgba(251,191,36,0.12);
      color: #fcd34d;
      border-left: 4px solid var(--amber);
      padding: 12px; 
      margin-top: -1px;
      font-size: 0.9em; 
    }
    
    table { 
      width: 100%; 
      border-collapse: collapse; 
      margin-bottom: 20px; 
      font-size: 0.9em; 
    }
    th, td { 
      border: 1px solid rgba(255,255,255,0.08);
      padding: 10px; 
      text-align: left; 
    }
    th {
      background: rgba(255,255,255,0.055);
      color: var(--muted);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-size: 0.78em;
    }
    td { color: var(--soft); }
    tr:hover td { background: rgba(34,211,238,0.055); }
    
    details {
      margin-bottom: 15px;
      border: 1px solid var(--line);
      padding: 12px;
      border-radius: 8px;
      background: rgba(255,255,255,0.04);
    }
    summary {
      font-weight: bold;
      cursor: pointer;
      outline: none;
      padding: 5px 0;
      color: var(--text);
    }
    .accepted-note {
      background: rgba(52,211,153,0.16);
      color: #86efac;
      font-size: 0.85em;
      padding: 4px 10px;
    }
    @media (max-width: 760px) {
      body { padding: 16px; }
      .container { padding: 18px; }
      table { display: block; overflow-x: auto; }
    }
  </style>
</head>
<body>
  <div class="container">
    {% macro status_badge(status) %}
      {% if status == "PASSED" %}
        <span class="badge badge-pass">PASSED</span>
      {% elif status == "FAILED" or status == "ERROR" %}
        <span class="badge badge-fail">{{ status }}</span>
      {% elif status == "SLOW" %}
        <span class="badge badge-amber">SLOW</span>
      {% elif status in ("RUNNING", "SKIPPED") %}
        <span class="badge badge-amber">{{ status }}</span>
      {% else %}
        <span class="badge badge-gray">{{ status }}</span>
      {% endif %}
    {% endmacro %}

    <div id="header">
      <h1>ETL Framework Execution Report</h1>
      <p><strong>Run ID:</strong> <span style="font-family: monospace;">{{ suite.run_id }}</span></p>
      <p><strong>Started:</strong> {{ suite.started_at }}</p>
      <p><strong>Environments:</strong> {{ suite.source_env }} &rarr; {{ suite.target_env }}</p>
      <hr>
    </div>

    <div id="summary">
      <h2>Summary</h2>
      <p>
        <strong>Total Tests:</strong> {{ suite.test_cases | length }} &nbsp;|&nbsp;
        <strong>Passed:</strong> <span style="color: #86efac; font-weight: bold;">{{ suite.total_passed }}</span> &nbsp;|&nbsp;
        <strong>Failed/Error:</strong> <span style="color: #fda4af; font-weight: bold;">{{ suite.total_failed }}</span> &nbsp;|&nbsp;
        <strong>Skipped:</strong> {{ suite.total_skipped }}
      </p>
    </div>

    <div id="recon">
      <h2>Reconciliation Results</h2>
      <table>
        <thead>
          <tr>
            <th>Test Name</th>
            <th>Status</th>
            <th>Duration</th>
            <th>Source Rows</th>
            <th>Target Rows</th>
            <th>Mismatches</th>
          </tr>
        </thead>
        <tbody>
          {% for result in suite.reconciliation_results %}
          <tr>
            <td style="font-family: monospace;">{{ result.query_name }}</td>
            <td>{{ status_badge(result.status) }}</td>
            <td>{{ "%.2f"|format(result.duration_seconds) if result.duration_seconds else "N/A" }}s</td>
            <td>{{ result.source_row_count }}</td>
            <td>{{ result.target_row_count }}</td>
            <td style="{% if result.total_issues > 0 %}color: #fda4af; font-weight: bold;{% endif %}">{{ result.total_issues }}</td>
          </tr>
          {% if result.schema_diff %}
          <tr>
            <td colspan="6" style="padding: 0; border: none;">
              <div class="warning-banner">
                <strong>⚠️ Schema Mismatch Warning</strong>
                <ul style="margin: 5px 0 0 0; padding-left: 20px;">
                  {% if result.schema_diff.missing_in_target %}
                  <li><strong>Missing in Target:</strong> {{ result.schema_diff.missing_in_target | join(', ') }}</li>
                  {% endif %}
                  {% if result.schema_diff.extra_in_target %}
                  <li><strong>Extra in Target:</strong> {{ result.schema_diff.extra_in_target | join(', ') }}</li>
                  {% endif %}
                </ul>
              </div>
            </td>
          </tr>
          {% endif %}
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div id="mismatches">
      {% for result in suite.reconciliation_results %}
        {% if result.mismatches %}
          <details>
            <summary>{{ result.query_name }} Mismatches (Showing first {{ result.mismatches|length }})</summary>
            <table>
              <thead>
                <tr>
                  <th>Mismatch Type</th>
                  <th>Column</th>
                  <th>Row Key Values</th>
                  <th>Source Value</th>
                  <th>Target Value</th>
                </tr>
              </thead>
              <tbody>
                {% for mm in result.mismatches %}
                <tr>
                  <td><span class="badge badge-gray">{{ mm.mismatch_type }}</span></td>
                  <td>{{ mm.column_name }}</td>
                  <td style="font-family: monospace; font-size: 0.85em;">{{ mm.key_values }}</td>
                  <td style="color: #fda4af;">{{ mm.source_value }}</td>
                  <td style="color: #86efac;">{{ mm.target_value }}</td>
                </tr>
                {% if mm.accepted %}
                <tr style="background: rgba(52,211,153,0.12);">
                  <td colspan="5" class="accepted-note">
                    ✓ Accepted{% if mm.accepted_by %} by {{ mm.accepted_by }}{% endif %}{% if mm.accepted_at %} on {{ mm.accepted_at.strftime('%Y-%m-%d %H:%M') }}{% endif %}{% if mm.accepted_note %} — {{ mm.accepted_note }}{% endif %}
                  </td>
                </tr>
                {% endif %}
                {% endfor %}
              </tbody>
            </table>
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</body>
</html>
